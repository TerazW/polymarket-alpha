# ============================================================================
# Belief Reaction System - Environment Configuration
# ============================================================================
# Copy this file to .env and update values as needed
# ============================================================================

# =============================================================================
# DATABASE
# =============================================================================
# For development with SQLite (simple, no setup needed)
DATABASE_URL=sqlite:///data/market_sensemaking.db

# For production with PostgreSQL/TimescaleDB (recommended)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/belief_reaction

# Connection pool settings (PostgreSQL only)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# =============================================================================
# POLYMARKET APIs
# =============================================================================
# WebSocket endpoint for real-time market data
WS_MARKET_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
WS_PING_INTERVAL=10

# REST APIs
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_REST_BASE_URL=https://clob.polymarket.com
DATA_API_BASE_URL=https://data-api.polymarket.com

# =============================================================================
# SHOCK DETECTION THRESHOLDS
# =============================================================================
# Time window for shock volume calculation (ms)
SHOCK_TIME_WINDOW_MS=2000

# Trade volume ratio to trigger shock (0.35 = 35%)
SHOCK_VOLUME_THRESHOLD=0.35

# Number of consecutive trades at same price to trigger shock
SHOCK_CONSECUTIVE_TRADES=3

# =============================================================================
# REACTION CLASSIFICATION THRESHOLDS
# =============================================================================
# Observation window after shock (ms)
REACTION_WINDOW_MS=20000

# Sampling interval during observation (ms)
REACTION_SAMPLE_INTERVAL_MS=500

# Refill ratio threshold for HOLD classification
HOLD_REFILL_THRESHOLD=0.8

# Time to refill threshold for HOLD classification (ms)
HOLD_TIME_THRESHOLD_MS=5000

# Liquidity ratio threshold for VACUUM classification
VACUUM_THRESHOLD=0.05

# Liquidity ratio threshold for PULL classification
PULL_THRESHOLD=0.1

# =============================================================================
# BELIEF STATE MACHINE
# =============================================================================
# Number of key levels to track per side
KEY_LEVELS_COUNT=5

# Lookback period for identifying key levels (hours)
KEY_LEVELS_LOOKBACK_HOURS=24

# Number of recent reactions to consider for state transitions
STATE_REACTION_WINDOW=10

# =============================================================================
# COLLECTOR
# =============================================================================
# Binning interval for book_bins (ms)
BIN_INTERVAL_MS=250

# Maximum number of markets to monitor
MAX_MARKETS=100

# Reconnection delay after disconnect (seconds)
RECONNECT_DELAY_S=5

# Maximum reconnection attempts before giving up
MAX_RECONNECT_ATTEMPTS=10

# =============================================================================
# REDIS (Optional)
# =============================================================================
# Redis URL for real-time event streaming
# Leave empty to disable Redis
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# LEGACY (from old system, may still be used)
# =============================================================================
UPDATE_INTERVAL_MINUTES=30
TOP_MARKETS_COUNT=50
