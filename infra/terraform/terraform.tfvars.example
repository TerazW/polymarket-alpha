# =============================================================================
# Market Sensemaking - Terraform Variables Example
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git (contains sensitive data)

# -----------------------------------------------------------------------------
# TimescaleDB Cloud Configuration
# -----------------------------------------------------------------------------

use_timescaledb_cloud = true

# Get these values from TimescaleDB Cloud console after creating your service
timescaledb_host     = "xxx.tsdb.cloud.timescale.com"
timescaledb_port     = "5432"
timescaledb_name     = "tsdb"
timescaledb_user     = "tsdbadmin"
timescaledb_password = "your-password-here"

# -----------------------------------------------------------------------------
# Optional: Override other defaults
# -----------------------------------------------------------------------------

# aws_region = "us-east-1"
# environment = "production"
# alarm_email = "alerts@example.com"
